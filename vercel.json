{
  "redirects": [
    {
      "source": "/contact",
      "destination": "https://www.atulsharmas.in/contact-owner",
      "permanent": true
    },
    {
      "source": "/articles/how-to-stay-focused-while-studying-2026",
      "destination": "https://www.atulsharmas.in/articles/how-to-study-effectively-2026-best-study-techniques",
      "permanent": true
    },
    {
      "source": "/articles/how-to-start-freelancing-as-student-2026",
      "destination": "https://www.atulsharmas.in/articles/how-to-start-freelancing-as-a-student-2026",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "atulsharmas.in" }
      ],
      "destination": "https://www.atulsharmas.in/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://pagead2.googlesyndication.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; connect-src 'self' https://lryyihefzqpjiedtrdeg.supabase.co https://*.supabase.co https://cdn.sanity.io https://3k3t106k.apicdn.sanity.io https://3k3t106k.api.sanity.io https://www.google-analytics.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" }
      ]
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/" }
  ]
}
